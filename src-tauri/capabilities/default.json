{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main RNAmeta window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "r-engine",
          "cmd": "$RESOURCE/resources/r-lang/bin/Rscript.exe",
          "args": true
        }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALDATA/**" },
        { "path": "$CACHE/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALDATA/**" },
        { "path": "$CACHE/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "/**" }
      ]
    }
  ]
}
