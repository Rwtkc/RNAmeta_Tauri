{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "r-engine",
          "cmd": "$RESOURCE/resources/r-lang/bin/Rscript.exe",
          "args": true
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" },
        { "path": "G:\\**" },
        { "path": "H:\\**" },
        { "path": "I:\\**" },
        { "path": "J:\\**" },
        { "path": "Z:\\**" },
        { "path": "/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" },
        { "path": "/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "/**" }
      ]
    },
    "fs:default"
  ]
}
